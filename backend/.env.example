# Copia este archivo como .env y completa los valores.

# ===== Base de datos =====
# Opción A (desarrollo / red local, actual): SQLite, un archivo en disco.
DATABASE_URL="file:./dev.db"
#
# Opción B (producción / acceso por internet, recomendado): PostgreSQL.
# Con el docker-compose.yml incluido, la URL local es:
# DATABASE_URL="postgresql://inventario:inventario_local_pass@localhost:5432/inventario?schema=public"
# En un servidor real usa el host/usuario/clave de tu proveedor (Railway, Render, Neon, etc.).

# ===== Servidor =====
# Puerto del servidor API
PORT=4000

# Entorno: en producción usa "production" (oculta el detalle de los errores 500 al cliente).
NODE_ENV=development

# ===== Seguridad =====
# Secreto para firmar los tokens JWT. OBLIGATORIO (mínimo 16 caracteres).
# Genera uno fuerte con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="reemplaza-por-un-secreto-largo-y-aleatorio"

# Duración de la sesión (formato de la librería jsonwebtoken). Opcional, por defecto 12h.
JWT_EXPIRES_IN="12h"

# Orígenes permitidos para el frontend (CORS), separados por coma.
# Vacío = permite cualquier origen (cómodo en desarrollo / red local).
# En producción fíjalo:  CORS_ORIGIN="https://inventario.tudominio.com"
CORS_ORIGIN=
