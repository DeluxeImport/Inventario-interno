# Copia este archivo como .env y completa los valores.

# ===== Base de datos =====
# PostgreSQL. Con el docker-compose.yml incluido, la URL local es:
DATABASE_URL="postgresql://inventario:inventario_local_pass@localhost:5432/inventario?schema=public"
# En un servidor real usa el host/usuario/clave de tu proveedor (Railway, Render, Neon, etc.).

# ===== Servidor =====
# Puerto del servidor API
PORT=4000

# Entorno: en producción usa "production" (oculta el detalle de los errores 500 al cliente).
NODE_ENV=development

# ===== Seguridad =====
# Secreto para firmar los tokens JWT. OBLIGATORIO (mínimo 16 caracteres).
# Genera uno fuerte con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET="reemplaza-por-un-secreto-largo-y-aleatorio"

# Duración de la sesión (formato de la librería jsonwebtoken). Opcional, por defecto 12h.
JWT_EXPIRES_IN="12h"

# Orígenes permitidos para el frontend (CORS), separados por coma.
# Vacío = permite cualquier origen solo en desarrollo / red local.
# En producción es obligatorio: CORS_ORIGIN="https://inventario.tudominio.com"
CORS_ORIGIN=

# ===== Notificaciones por WhatsApp (opcional, vía CallMeBot) =====
# Configura ambas variables para recibir avisos al crear una solicitud,
# cuando el stock pasa a bajo/agotado o cuando una entrega falla por falta de stock.
# Activa tu número y obtén la API key en:
# https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Teléfono con código de país y sin espacios (ejemplo: +51987654321).
CALLMEBOT_PHONE=
CALLMEBOT_APIKEY=
